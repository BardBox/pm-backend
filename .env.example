# Server
PORT=8090

# MongoDB - Use a NEW database for PM
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# CORS - comma-separated origins
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# Email (Gmail SMTP)
CLIENT_EMAIL=your-email@gmail.com
APP_PASSWORD_EMAIL=your-app-password
MAILERLITE_FROM_EMAIL=your-from-email@domain.com

# MailerLite
MAILERLITE_API_KEY=your-mailerlite-api-key

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# TFT WhatsApp API
TFT_WHATSAPP_API_KEY=your-tft-api-key
TFT_WHATSAPP_API_URL=https://official.thefuturetech.in/wapp/api/v2/send/bytemplate
TFT_WHATSAPP_CHANNEL=919558708295
